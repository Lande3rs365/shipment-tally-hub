# Shipment Tally Hub — Environment Variables
# Copy this file to .env and fill in your values.
# Get these from your Supabase project dashboard → Settings → API.

# Your Supabase project URL (e.g. https://<project-id>.supabase.co)
VITE_SUPABASE_URL=https://<project-id>.supabase.co

# Supabase anon/public key — safe to use client-side (RLS enforces access control)
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-key>

# Supabase project ID (the subdomain portion of your project URL)
VITE_SUPABASE_PROJECT_ID=<project-id>

# Optional: Sentry error tracking
# Get this from: sentry.io → Project → Settings → Client Keys (DSN)
# Leave blank to disable Sentry
VITE_SENTRY_DSN=
